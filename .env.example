POSTMARK_SERVER_TOKEN=your_postmark_server_token
POSTMARK_FROM_EMAIL=Impulse Notifications <notifications@emails.impulse.ky>
POSTMARK_TO_EMAIL=bmolina@impulse.ky

# Comma-separated list of origins allowed to call the /api/contact endpoint
# cross-origin (e.g. https://impulse.ky,https://www.impulse.ky). The site's own
# forms post same-origin and do not need this; leave unset for same-origin only.
ALLOWED_ORIGIN=
