POSTMARK_SERVER_TOKEN=your_postmark_server_token
POSTMARK_FROM_EMAIL=Impulse Notifications <notifications@emails.impulse.ky>
POSTMARK_TO_EMAIL=bmolina@impulse.ky

# Comma-separated list of origins allowed to call the /api/contact endpoint
# cross-origin (e.g. https://impulse.ky,https://www.impulse.ky). The public site
# is served from a different origin than this Vercel function, so the forms post
# cross-origin. Leave UNSET to allow any origin ("*"); set it to lock the
# endpoint down to the production domain(s).
ALLOWED_ORIGIN=
